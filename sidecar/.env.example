# Copy to .env (gitignored) and fill in. Never commit real credentials.
TECO_USER=your_portal_username
TECO_PASS=your_portal_password

# Optional shared secret. If set, the HA integration must send the same value
# as 'X-Auth-Token'. Generate one with: openssl rand -hex 24
SIDECAR_TOKEN=

# Re-login if the browser session is older than this many minutes.
SESSION_TTL_MIN=30
